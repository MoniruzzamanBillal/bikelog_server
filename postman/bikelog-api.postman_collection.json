    {
      "name": "Fuel Logs",
      "item": [
        {
          "name": "Create Fuel Log",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/bikes/{{bikeId}}/fuel-logs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "bikes",
                "{{bikeId}}",
                "fuel-logs"
              ]
            },
            "description": "Never send `totalCost` — it's always server-computed as litersAdded * pricePerLiter and any client value is discarded. Response shape is `data.fuelLog` (+ `data.mileageRecordClosed` if isFullTank closed a period).",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"odometerReading\": 1550,\n  \"litersAdded\": 8.5,\n  \"isFullTank\": true,\n  \"pricePerLiter\": 125.5,\n  \"fuelStation\": \"Padma Filling Station\",\n  \"date\": \"2026-07-01\",\n  \"notes\": \"Full tank before highway trip\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.expect([201]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code < 300) {",
                  "    const body = pm.response.json();",
                  "    const value = body.data.fuelLog._id;",
                  "    if (value) {",
                  "        pm.collectionVariables.set(\"fuelLogId\", value);",
                  "        console.log(\"Captured fuelLogId =\", value);",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Fuel Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bikes/{{bikeId}}/fuel-logs?page=1&limit=10&sort=-date",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "bikes",
                "{{bikeId}}",
                "fuel-logs"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "disabled": false
                },
                {
                  "key": "limit",
                  "value": "10",
                  "disabled": false
                },
                {
                  "key": "sort",
                  "value": "-date",
                  "disabled": false
                },
                {
                  "key": "isFullTank",
                  "value": "true",
                  "disabled": true
                }
              ]
            },
            "description": "Supports pagination (page/limit), sort, and field filters via QueryBuilder. `bike`/`isDeleted` query keys are ignored server-side (IDOR hardening) even if you set them."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.expect([200]).to.include(pm.response.code);",
                  "});"
                ]
