            },
            "description": "`owner` is taken from the JWT, never send it. `currentOdometer` here seeds the bike's immutable `initialOdometer` too; it's optional (defaults to 0).",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nickname\": \"Red Beast\",\n  \"brand\": \"Yamaha\",\n  \"model\": \"FZS V3\",\n  \"registrationNumber\": \"DHAKA-METRO-GA-11-2233\",\n  \"purchaseDate\": \"2024-01-15\",\n  \"fuelTankCapacityLiters\": 12,\n  \"currentOdometer\": 1500\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.expect([201]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code < 300) {",
                  "    const body = pm.response.json();",
                  "    const value = body.data._id;",
                  "    if (value) {",
                  "        pm.collectionVariables.set(\"bikeId\", value);",
                  "        console.log(\"Captured bikeId =\", value);",
                  "    }",
                  "}"
                ]
