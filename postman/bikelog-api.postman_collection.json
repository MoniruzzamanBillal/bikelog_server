        {
          "name": "Update Fuel Log",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/bikes/{{bikeId}}/fuel-logs/{{fuelLogId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "bikes",
                "{{bikeId}}",
                "fuel-logs",
                "{{fuelLogId}}"
              ]
            },
            "description": "Fails with 409 if this fuel log was already closed into a mileage record. `totalCost` is recomputed server-side whenever litersAdded/pricePerLiter change; a client-sent totalCost is dropped.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"odometerReading\": 1560,\n  \"notes\": \"Corrected odometer reading\"\n}",
              "options": {
                "raw": {
                  "language": "json"
