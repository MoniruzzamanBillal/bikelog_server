              "raw": "{{baseUrl}}/bikes/{{bikeId}}/fuel-logs/{{fuelLogId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "bikes",
                "{{bikeId}}",
                "fuel-logs",
                "{{fuelLogId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
