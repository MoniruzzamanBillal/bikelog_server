{
  "info": {
    "name": "Bike Log API",
    "description": "Backend API for the Bike Log app (Express + TypeScript + Mongoose). Auth via JWT Bearer token — run Auth > Login first (after Auth > Register once), which auto-captures {{token}}. Then run Bikes > Create Bike, Maintenance Types > Create Maintenance Type, and Engine Oil Types > Create Engine Oil Type to auto-capture the ids the rest of the collection chains off of. See dummy-data.md in this folder for the full field reference.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "bikeId",
      "value": "",
      "type": "string"
    },
    {
      "key": "fuelLogId",
      "value": "",
      "type": "string"
    },
    {
      "key": "maintenanceTypeId",
      "value": "",
      "type": "string"
    },
    {
      "key": "engineOilTypeId",
      "value": "",
      "type": "string"
    },
    {
      "key": "maintenanceLogId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Creates a new user. Response never includes the password hash. If the email already exists, returns 409 Conflict.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Rider\",\n  \"email\": \"rider@example.com\",\n  \"password\": \"test1234\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.expect([200]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Logs in and returns a JWT at the top-level `token` field (not under `data`). The test script below saves it into the `token` collection variable automatically, so every other request in this collection (which use Bearer {{token}}) will work right after this runs.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"rider@example.com\",\n  \"password\": \"test1234\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.expect([200]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code < 300) {",
                  "    const body = pm.response.json();",
                  "    const value = body.token;",
                  "    if (value) {",
                  "        pm.collectionVariables.set(\"token\", value);",
                  "        console.log(\"Captured token =\", value);",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.expect([200]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
